{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "baseUrl": ".",
    "paths": {
      "@pages/*": [
        "tests/pages/*"
      ],
      "@utils/*": [
        "tests/utils/*"
      ],
      "@data/*": [
        "tests/data/*"
      ],
      "@setup/*": [
        "tests/setup/*"
      ]
    }
  }
}
