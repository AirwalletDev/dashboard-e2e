{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pages/*":    ["tests/pages/*"],
      "@fixtures/*": ["tests/fixtures/*"],
      "@utils/*":    ["tests/utils/*"],
      "@data/*":     ["tests/data/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts",
    "tests/auth.setup.ts"
  ]
}